# ===========================================================================
# AI 커뮤니티 — 환경변수 예시 (.env.example)
# 실제 값은 .env 로 복사해서 채우세요. .env 는 git 에 커밋되지 않습니다.
# ===========================================================================

# --- Spring profile ---
# local  : Docker 없이 실행 (H2 파일 DB + 인메모리 캐시)  ← 기본
# docker : docker-compose 의 PostgreSQL + Redis 사용
SPRING_PROFILES_ACTIVE=local

# --- 주 데이터베이스 (PostgreSQL) : docker 프로필에서 사용 ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=aicommunity
POSTGRES_USER=aicommunity
POSTGRES_PASSWORD=aicommunity_dev_pw

# --- 캐시/세션 저장소 (Redis) : docker 프로필에서 사용 ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- JWT ---
# 운영에서는 반드시 32바이트 이상의 안전한 랜덤 값으로 교체하세요.
JWT_SECRET=dev-only-change-me-please-32bytes-minimum-secret-key
JWT_ACCESS_TTL_SECONDS=1800
JWT_REFRESH_TTL_SECONDS=604800

# --- 외부 API ---
# 큐레이션 서비스가 제보 URL 메타 정보를 수집할 때 사용 (선택)
GITHUB_API_TOKEN=
